# Local Spring profile. Use "postgres" to enable application-postgres.properties.
SPRING_PROFILES_ACTIVE=postgres

# Mongo canonical/ingest source (adjust db name as needed).
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/scholardex

# Postgres reporting-read store.
POSTGRES_URL=jdbc:postgresql://localhost:5432/core
POSTGRES_USER=core
POSTGRES_PASSWORD=core

# Read-store selector for migrated reporting surfaces.
# Keep "mongo" by default; switch to "postgres" only after H22 projection + gate checks.
APP_REPORTING_READ_STORE=mongo

# Optional H22 projector/gate toggles.
H22_PROJECTION_ENABLED=false
H22_PROJECTION_DRY_RUN=false
H22_DUAL_READ_GATE_P95_RATIO_THRESHOLD=1.2

# WoS pipeline optimization (ingest -> facts -> projections).
# Recommended starting values for local cutover/rebuild:
# - keep chunk sizes at 1000 first
# - increase identity LRU if you still see identity+filter spikes
CORE_WOS_OPTIMIZATION_FACT_CHUNK_SIZE=1000
CORE_WOS_OPTIMIZATION_INGEST_PERSIST_BATCH_SIZE=1000
CORE_WOS_OPTIMIZATION_PROJECTION_WRITE_CHUNK_SIZE=1000
CORE_WOS_OPTIMIZATION_IDENTITY_LRU_MAX_SIZE=200000
CORE_WOS_OPTIMIZATION_PREFLIGHT_INDEXES_ENABLED=true
CORE_WOS_OPTIMIZATION_TELEMETRY_HEARTBEAT_INTERVAL=10000
CORE_WOS_OPTIMIZATION_SLOW_CHUNK_THRESHOLD_MS=2000

# Optional external API key.
SCOPUS_API_KEY=replace-me
